    <title>新的开始</title>
    <link href="http://xiamianyu.github.io/2016/03/08/%E6%96%B0%E7%9A%84%E5%BC%80%E5%A7%8B/"/>
    <id>http://xiamianyu.github.io/2016/03/08/新的开始/</id>
